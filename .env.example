# Copiar a .env y completar.

# Puerto del servidor
PORT=3000

# Intervalo de polling del ESP32 en segundos (define el umbral de "desconectado" en la web = 2x este valor)
POLLING_SEG=300

# Token entre ESP32 y backend. Si queda VACÍO, no se exige (modo LAN).
# Completar solo si se expone la API a internet.
API_TOKEN=

# --- CallMeBot (alerta de WhatsApp cuando no hay agua) ---
# Número que recibe la alerta, en formato internacional sin "+" ni espacios. Ej: 5491112345678
CALLMEBOT_PHONE=
# API key que te devuelve CallMeBot tras activar el bot. Si queda vacío, la alerta se loguea pero no se envía.
CALLMEBOT_APIKEY=
